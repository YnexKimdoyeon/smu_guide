          "content": {
            "size": 31994,
            "mimeType": "text/css",
            "text": "/* common */\r\n.txtBox {\r\n    font-size: 16px;\r\n    color: #555;\r\n    line-height: 150%;\r\n    word-break: keep-all;\r\n}\r\n\r\nh3.h3Tit {\r\n    font-size: 23px;\r\n    color: #000;\r\n    padding-bottom: 20px;\r\n    font-weight: 600;\r\n}\r\n\r\n    h3.h3Tit:before {\r\n        padding-right: 8px;\r\n        background: url('/imagesN/bu_h3.png') no-repeat;\r\n        background-size: 12px 12px;\r\n        display: inline-block;\r\n        width: 12px;\r\n        height: 12px;\r\n        content: \"\";\r\n    }\r\n\r\nh3.space {\r\n    margin-top: 80px;\r\n}\r\n\r\nh4.h4Tit {\r\n    font-size: 18px;\r\n    color: #2868b4;\r\n    padding: 18px 0 12px;\r\n}\r\n\r\n.single-page-nav {\r\n    background: #ecf2f7;\r\n    padding: 40px;\r\n    margin-bottom: 60px;\r\n}\r\n\r\n.bu_circle:after {\r\n    content: \" \";\r\n    display: block;\r\n    clear: both;\r\n    height: 0;\r\n    visibility: hidden;\r\n}\r\n\r\n.bu_circle > li {\r\n    float: left;\r\n    width: 32%;\r\n    margin: 5px 0;\r\n    padding-left: 12px;\r\n    color: #000;\r\n    background: url('/imagesN/bu_circle.png') no-repeat 0 6px;\r\n}\r\n\r\n    .bu_circle > li a {\r\n        color: #000;\r\n    }\r\n\r\n.bu_normal > li {\r\n    padding-bottom: 10px;\r\n    font-size: 16px;\r\n    line-height: 150%;\r\n    word-break: keep-all;\r\n}\r\n\r\n.bu_dot > li {\r\n    padding-bottom: 10px;\r\n    padding-left: 12px;\r\n    font-size: 16px;\r\n    background: url('/imagesN/bu_gray.gif') no-repeat 0 12px;\r\n    line-height: 150%;\r\n    word-break: keep-all;\r\n}\r\n\r\n.bu_line {\r\n    margin-top: 5px;\r\n}\r\n\r\n    .bu_line > li {\r\n        padding-bottom: 10px;\r\n        padding-left: 10px;\r\n        font-size: 16px;\r\n        background: url('/imagesN/bu_line.gif') no-repeat 0 12px;\r\n        line-height: 150%;\r\n        word-break: keep-all;\r\n    }\r\n\r\n.lineBox {\r\n    border: 1px solid #e8e8e8;\r\n    margin-bottom: 30px;\r\n    padding: 30px;\r\n    border-radius: 15px;\r\n}\r\n\r\n.tbl_basic table {\r\n    width: 100%;\r\n    border-top: 2px solid #171940;\r\n    margin: 0 0 20px;\r\n    text-align: center;\r\n    border-collapse: collapse;\r\n    border-spacing: 0;\r\n}\r\n\r\n    .tbl_basic table thead th {\r\n        background: #f2f3f6;\r\n        padding: 15px;\r\n        border: 1px solid #ddd;\r\n        color: #000;\r\n    }\r\n\r\n    .tbl_basic table tbody th {\r\n        background: #f8f8f8;\r\n        padding: 15px;\r\n        border: 1px solid #ddd;\r\n        color: #000;\r\n    }\r\n\r\n    .tbl_basic table tbody td {\r\n        padding: 15px;\r\n        border: 1px solid #ddd;\r\n        line-height: 130%;\r\n    }\r\n\r\n    .tbl_basic table tbody .bgb {\r\n        background: #f0f6f6;\r\n    }\r\n\r\n    .tbl_basic table tbody td li {\r\n        text-align: left;\r\n    }\r\n\r\n    .tbl_basic table tbody td select {\r\n        height: 30px;\r\n        border: 1px solid #ddd;\r\n    }\r\n\r\n    .tbl_basic table tbody td input[type=text] {\r\n        height: 30px;\r\n        border: 1px solid #ddd;\r\n        padding: 0 10px;\r\n    }\r\n\r\n/* 탭 */\r\n/*반응형 전*/\r\n/*.tabmenu.tab_5ea\r\n.tabmenu.tab_5ea > *\t{padding-bottom:1px;}\r\n.tabmenu.tab_5ea > * > li\t{float:left; width:20%; margin-bottom:-1px;}\r\n.tabmenu.tab_5ea > * > li > span\t{display:block; border:1px solid #e2e2e2; border-left:0; padding-right:20px; background:url(\"/images/sub/bg_tab_off.gif\") #fff no-repeat 100% 21px;}\r\n.tabmenu.tab_5ea > * > li > span a\t{display:block; padding:15px 0 17px 14px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;}\r\n.tabmenu.tab_5ea > * > li:first-child > span a\t{border-left:1px solid #e2e2e2;}\r\n.tabmenu.tab_5ea > * > li.on > span\t{border-color:#2868b4; background:url(\"/images/sub/bg_tab_on.gif\") #237491 no-repeat 100% 21px;}\r\n.tabmenu.tab_5ea > * > li.on > span a\t{border-color:#2868b4; color:#fff;}\r\n.tabmenu.tab_5ea > * > li:first-child + * + * + * + * + * > span\t{border-left:1px solid #e2e2e2;}\r\n.tabmenu.tab_5ea > * > li:first-child + * + * + * + * + * + * + * + * + * + * > span\t{border-left:1px solid #e2e2e2;}*/\r\n\r\n /*반응형*/\r\n.tabmenu.tab_5ea\r\n.tabmenu.tab_5ea > *    {padding-bottom:1px;}\r\n.tabmenu.tab_5ea ul {display: flex;justify-content: center; align-items: center;}\r\n.tabmenu.tab_5ea > * > li\t{width:20%; height: fit-content;}\r\n.tabmenu.tab_5ea > * > li > span\t{display:block; border:1px solid #e2e2e2; border-left:0; padding-right:20px; background:url(\"/images/sub/bg_tab_off.gif\") #fff no-repeat 100% 21px; border-top: 0;}\r\n.tabmenu.tab_5ea > * > li > span a  {display: block; padding: 15px 0 17px 14px; overflow: hidden; word-break: break-all; white-space: normal;}\r\n.tabmenu.tab_5ea > * > li:first-child > span a\t{border-left:1px solid #e2e2e2;}\r\n.tabmenu.tab_5ea > * > li.on > span\t{border-color:#2868b4; background:url(\"/images/sub/bg_tab_on.gif\") #237491 no-repeat 100% 21px;}\r\n.tabmenu.tab_5ea > * > li.on > span a\t{border-color:#2868b4; color:#fff;}\r\n.tabmenu.tab_5ea > * > li:first-child + * + * + * + * + * > span\t{border-left:1px solid #e2e2e2;}\r\n.tabmenu.tab_5ea > * > li:first-child + * + * + * + * + * + * + * + * + * + * > span\t{border-left:1px solid #e2e2e2;}\r\n\r\n@media (max-width:1224px) {\r\n    .tabmenu.tab_5ea li {\r\n        height: 68px;\r\n    }\r\n\r\n    .tabmenu.tab_5ea > * > li > span {\r\n        display: flex;\r\n        justify-content: left;\r\n        align-items: center;\r\n        height: 68px;\r\n    }\r\n}\r\n\r\n@media (max-width:714px) {\r\n    .tabmenu.tab_5ea li {\r\n        height: 86px;\r\n    }\r\n\r\n    .tabmenu.tab_5ea > * > li > span {\r\n        height: 86px;\r\n    }\r\n\r\n        .tabmenu.tab_5ea > * > li > span a {\r\n            font-size: 15px;\r\n        }\r\n}\r\n\r\n@media (max-width:500px) {\r\n    .tabmenu.tab_5ea ul {\r\n        flex-wrap: wrap;\r\n    }\r\n\r\n    .tabmenu.tab_5ea li {\r\n        width: 100%;\r\n        height: auto;\r\n    }\r\n\r\n    .tabmenu.tab_5ea > * > li > span {\r\n        height: auto;\r\n        border-top: 1px solid #e2e2e2;\r\n        border-left: 1px solid #e2e2e2;\r\n    }\r\n}\r\n\r\n\r\n.pageInfo {\r\n    margin-top: 80px;\r\n    border: 6px solid #e8e8e8;\r\n    padding: 25px 0;\r\n}\r\n\r\n    .pageInfo:after {\r\n        content: \" \";\r\n        display: block;\r\n        clear: both;\r\n        height: 0;\r\n        visibility: hidden;\r\n    }\r\n\r\n    .pageInfo dt {\r\n        float: left;\r\n        width: 150px;\r\n        text-align: center;\r\n    }\r\n\r\n        .pageInfo dt i {\r\n            font-size: 70px;\r\n            color: #2868b4;\r\n        }\r\n\r\n    .pageInfo dd {\r\n        float: right;\r\n        width: calc(100% - 150px);\r\n    }\r\n\r\n.tab {\r\n    overflow: hidden;\r\n    border-bottom: 1px solid #ddd;\r\n    text-align: center;\r\n}\r\n\r\n    .tab button {\r\n        display: inline-block;\r\n        background-color: inherit;\r\n        border: none;\r\n        outline: none;\r\n        cursor: pointer;\r\n        padding: 12px 15px;\r\n        color: #888;\r\n        transition: 0.2s;\r\n        font-size: 23px;\r\n        letter-spacing: -0.05em;\r\n    }\r\n\r\n        .tab button:hover {\r\n            color: #333;\r\n        }\r\n\r\n        .tab button.active {\r\n            color: #2868b4;\r\n            border-bottom: 4px solid #2868b4\r\n        }\r\n\r\n.tabcontent {\r\n    display: none;\r\n    padding-top: 50px;\r\n}\r\n\r\n#top_btn {\r\n    position: fixed;\r\n    bottom: 20px;\r\n    right: 20px;\r\n    width: 40px;\r\n    height: 40px;\r\n    line-height: 40px;\r\n    border: 2px solid #333;\r\n    color: #333;\r\n    text-align: center;\r\n    font-size: 17px;\r\n    z-index: 90;\r\n    background: rgba(255,255,255,0.5)\r\n}\r\n\r\n    #top_btn:hover {\r\n        border-color: #333;\r\n        background: #333;\r\n    }\r\n\r\n        #top_btn:hover i {\r\n            color: #fff\r\n        }\r\n\r\n.tbl_scroll2 .tbl_basic {\r\n    min-width: 1200px;\r\n    width: 100%;\r\n}\r\n/* 학생활동/지원 > Job Cafe */\r\n.tbl_scroll2 {\r\n    overflow: auto;\r\n}\r\n\r\n\r\n@media (max-width: 1024px) {\r\n    .single-page-nav {\r\n        padding: 30px;\r\n        margin-bottom: 50px\r\n    }\r\n\r\n    .bu_circle > li {\r\n        float: left;\r\n        width: calc(50% - 12px);\r\n        margin: 5px 0;\r\n    }\r\n}\r\n\r\n@media (max-width: 850px) {\r\n    .txtBox {\r\n        font-size: 15px;\r\n    }\r\n\r\n    h3.h3Tit {\r\n        font-size: 20px;\r\n        padding-bottom: 18px;\r\n    }\r\n\r\n        h3.h3Tit:before {\r\n            width: 12px;\r\n            height: 12px\r\n        }\r\n\r\n    h3.space {\r\n        margin-top: 60px;\r\n    }\r\n\r\n    h4.h4Tit {\r\n        font-size: 17px;\r\n        padding: 16px 0 10px;\r\n    }\r\n\r\n    .bu_normal > li {\r\n        padding-bottom: 8px;\r\n        font-size: 15px;\r\n    }\r\n\r\n    .bu_dot > li {\r\n        padding-bottom: 8px;\r\n        padding-left: 10px;\r\n        font-size: 15px;\r\n        background: url('/imagesN/bu_gray.gif') no-repeat 0 9px;\r\n    }\r\n\r\n    .bu_line > li {\r\n        padding-bottom: 8px;\r\n        padding-left: 10px;\r\n        font-size: 15px;\r\n        background: url('/imagesN/bu_line.gif') no-repeat 0 9px;\r\n    }\r\n\r\n    .lineBox {\r\n        padding: 20px;\r\n        border-radius: 10px;\r\n    }\r\n\r\n    .tbl_basic table thead th {\r\n        font-size: 15px;\r\n        padding: 12px 5px;\r\n    }\r\n\r\n    .tbl_basic table tbody th,\r\n    .tbl_basic table tbody td {\r\n        font-size: 15px;\r\n        padding: 12px 5px;\r\n    }\r\n\r\n    .tbl_scroll .tbl_basic {\r\n        min-width: 850px;\r\n        width: 100%;\r\n    }\r\n\r\n    .tbl_scroll {\r\n        overflow: auto;\r\n    }\r\n\r\n    .pageInfo {\r\n        margin-top: 60px;\r\n        border: 4px solid #e8e8e8;\r\n        padding: 15px 0;\r\n    }\r\n\r\n        .pageInfo dt {\r\n            width: 100px;\r\n        }\r\n\r\n            .pageInfo dt i {\r\n                font-size: 50px;\r\n            }\r\n\r\n        .pageInfo dd {\r\n            width: calc(100% - 100px);\r\n        }\r\n\r\n            .pageInfo dd span {\r\n                font-size: 15px;\r\n            }\r\n\r\n    .tab button {\r\n        padding: 10px 12px;\r\n        font-size: 20px;\r\n    }\r\n\r\n    .tabcontent {\r\n        display: none;\r\n        padding-top: 30px;\r\n    }\r\n}\r\n\r\n@media (max-width: 640px) {\r\n    h3.space {\r\n        margin-top: 50px;\r\n    }\r\n\r\n    .single-page-nav {\r\n        padding: 20px;\r\n        margin-bottom: 40px\r\n    }\r\n\r\n\r\n    .tab button {\r\n        padding: 10px 5px;\r\n        font-size: 16px;\r\n    }\r\n\r\n        .tab button.active {\r\n            border-bottom: 3px solid #2868b4\r\n        }\r\n\r\n    .tabcontent {\r\n        display: none;\r\n        padding-top: 25px;\r\n    }\r\n\r\n    #top_btn {\r\n        bottom: 15px;\r\n        right: 15px;\r\n        width: 32px;\r\n        height: 32px;\r\n        line-height: 32px;\r\n        font-size: 15px;\r\n        z-index: 90;\r\n        background: rgba(255,255,255,0.5)\r\n    }\r\n}\r\n\r\n@media (max-width: 480px) {\r\n    h3.h3Tit {\r\n        font-size: 18px;\r\n        padding-bottom: 15px;\r\n    }\r\n\r\n    h3.space {\r\n        margin-top: 40px;\r\n    }\r\n\r\n    h4.h4Tit {\r\n        font-size: 16px;\r\n        padding: 13px 0 8px;\r\n    }\r\n\r\n    .bu_circle > li {\r\n        float: left;\r\n        width: calc(100% - 12px);\r\n        margin: 4px 0;\r\n    }\r\n\r\n    .tbl_basic table thead th,\r\n    .tbl_basic table tbody th,\r\n    .tbl_basic table tbody td {\r\n        padding: 10px 5px;\r\n    }\r\n\r\n    .pageInfo {\r\n        margin-top: 40px;\r\n        border: 3px solid #e8e8e8;\r\n        padding: 12px 0;\r\n    }\r\n\r\n        .pageInfo dt {\r\n            width: 75px;\r\n        }\r\n\r\n            .pageInfo dt i {\r\n                font-size: 40px;\r\n            }\r\n\r\n        .pageInfo dd {\r\n            width: calc(100% - 75px);\r\n        }\r\n}\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n/* btn */\r\n.btnBox_bottom {\r\n    margin-top: 50px;\r\n    text-align: center;\r\n}\r\n\r\na.btn_send {\r\n    display: inline-block;\r\n    padding: 10px 15px;\r\n    font-size: 16px;\r\n    color: #fff;\r\n    background: #2868b4;\r\n    border-radius: 3px;\r\n}\r\n\r\na.btn_cancel {\r\n    display: inline-block;\r\n    padding: 10px 15px;\r\n    font-size: 16px;\r\n    color: #666;\r\n    background: #e8e8e8;\r\n    border-radius: 3px;\r\n}\r\n\r\n.btn_big {\r\n    display: inline-block;\r\n    padding: 10px 15px;\r\n    font-size: 18px;\r\n    color: #000;\r\n    background: #fff;\r\n    border: 1px solid #ddd;\r\n    min-width: 280px;\r\n    position: relative;\r\n}\r\n\r\n    .btn_big i {\r\n        position: absolute;\r\n        right: 10px;\r\n        top: 10px;\r\n    }\r\n\r\n        .btn_big i img {\r\n            width: 20px;\r\n        }\r\n\r\n.btn_blue {\r\n    display: inline-block;\r\n    background: #2868b4;\r\n    color: #fff;\r\n    padding: 15px 15px;\r\n    font-size: 18px;\r\n    border: none;\r\n    min-width: 400px;\r\n}\r\n\r\n.btn_tblDown {\r\n    display: inline-block;\r\n    padding: 5px 10px;\r\n    font-size: 14px;\r\n    color: #000;\r\n    border: 1px solid #ddd;\r\n}\r\n\r\n    .btn_tblDown i {\r\n        font-size: 16px;\r\n        padding-left: 5px;\r\n        color: #2868b4;\r\n        vertical-align: middle;\r\n    }\r\n\r\n@media (max-width: 850px) {\r\n    .btnBox_bottom {\r\n        margin-top: 40px;\r\n    }\r\n\r\n    .btn_big {\r\n        padding: 8px 12px;\r\n        font-size: 16px;\r\n        min-width: 240px;\r\n    }\r\n\r\n        .btn_big i {\r\n            right: 8px;\r\n            top: 8px;\r\n        }\r\n\r\n            .btn_big i img {\r\n                width: 18px;\r\n            }\r\n\r\n    .btn_blue {\r\n        padding: 15px 12px;\r\n        min-width: 350px;\r\n    }\r\n}\r\n\r\n@media (max-width: 640px) {\r\n    .btn_big {\r\n        padding: 8px 10px;\r\n        min-width: 220px;\r\n    }\r\n\r\n    .btn_blue {\r\n        padding: 12px 8px;\r\n        font-size: 17px;\r\n        min-width: 300px;\r\n    }\r\n}\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n/* 학적 */\r\n.step_register.st4 li {\r\n    float: left;\r\n    width: 23%;\r\n    margin: 0 1%;\r\n    text-align: center;\r\n}\r\n\r\n.step_register.st6 > li {\r\n    float: left;\r\n    width: 17.6%;\r\n    margin: 0 1%;\r\n    text-align: center;\r\n}\r\n\r\n.step_register li:nth-child(even) div {\r\n    background: #016fd1;\r\n    border-radius: 20px;\r\n}\r\n\r\n.step_register li:nth-child(odd) div {\r\n    background: #1e9aec;\r\n    border-radius: 20px;\r\n}\r\n\r\n.step_register li > div img {\r\n    padding: 20px 0;\r\n    width: 50px;\r\n}\r\n\r\n.step_register li p {\r\n    font-size: 18px;\r\n    padding: 15px 0 8px;\r\n    color: #000;\r\n    font-weight: 600;\r\n}\r\n\r\n.step_register li span {\r\n    display: block;\r\n    font-size: 14px;\r\n    color: #555;\r\n    word-break: keep-all;\r\n}\r\n\r\n.step_register li li {\r\n    display: block;\r\n    font-size: 14px;\r\n    color: #555;\r\n    word-break: keep-all;\r\n    text-align: left;\r\n}\r\n\r\n@media (max-width: 1024px) {\r\n    .step_register li > div img {\r\n        padding: 18px 0;\r\n        width: 45px;\r\n    }\r\n}\r\n\r\n@media (max-width: 850px) {\r\n    .step_register.st4 li {\r\n        width: 24%;\r\n        margin: 0 0.5%;\r\n    }\r\n\r\n    .step_register.st6 > li {\r\n        width: 32%;\r\n        margin: 0 0.5%;\r\n    }\r\n\r\n    .step_register li:nth-child(even) div,\r\n    .step_register li:nth-child(odd) div {\r\n        border-radius: 10px;\r\n    }\r\n\r\n    .step_register li > div img {\r\n        padding: 10px 0;\r\n        width: 35px;\r\n    }\r\n\r\n    .step_register li p {\r\n        font-size: 17px;\r\n        padding: 12px 0 5px;\r\n    }\r\n\r\n        .step_register li p br {\r\n            display: none;\r\n        }\r\n}\r\n\r\n@media (max-width: 580px) {\r\n    .step_register li {\r\n        width: 100% !important;\r\n        margin: 0 0 10px !important;\r\n    }\r\n\r\n        .step_register li:after {\r\n            content: \" \";\r\n            display: block;\r\n            clear: both;\r\n            height: 0;\r\n            visibility: hidden;\r\n        }\r\n    /*.step_register li div\t\t\t\t\t{float:left; width:80px;}\r\n\t.step_register li p\t\t\t\t\t\t{float:right; font-size:16px; width:calc(100% - 95px); padding:12px 0 5px; text-align:left;}\r\n\t.step_register li span \t\t\t\t\t{float:right; width:calc(100% - 95px); text-align:left;}*/\r\n}\r\n\r\n\r\n\r\n/* 재입학 */\r\n.faqBox {\r\n    border-top: 2px solid #171940;\r\n}\r\n\r\n    .faqBox .accordion {\r\n        position: relative;\r\n        font-size: 16px;\r\n        background: #fff;\r\n        color: #444;\r\n        cursor: pointer;\r\n        padding: 20px 0 20px 60px;\r\n        width: 100%;\r\n        border: none;\r\n        border-bottom: 1px solid #ececec;\r\n        text-align: left;\r\n        outline: none;\r\n        transition: 0.2s;\r\n    }\r\n\r\n.accordion:hover {\r\n    background: #fafafa;\r\n}\r\n/*.accordion:after\t\t\t\t\t\t{content: '\\002B'; color: #777; font-weight: bold; float: right; margin-right:10px; }\r\n.active:after\t\t\t\t\t\t\t{content: \"\\2212\";}*/\r\n.accordion .tit_bg {\r\n    display: inline-block;\r\n    position: absolute;\r\n    top: 11px;\r\n    left: 10px;\r\n    text-align: center;\r\n    background: #f2f3f6;\r\n    color: #000;\r\n    border-radius: 50%;\r\n    width: 35px;\r\n    height: 35px;\r\n    font-weight: bold;\r\n    font-size: 18px;\r\n    line-height: 35px;\r\n}\r\n\r\n.panel {\r\n    position: relative;\r\n    background: #f8f8f8;\r\n    padding: 0;\r\n    max-height: 0;\r\n    overflow: hidden;\r\n    transition: max-height 0.2s ease-out;\r\n}\r\n\r\n    .panel .tit_bg {\r\n        display: inline-block;\r\n        position: absolute;\r\n        top: 11px;\r\n        left: 10px;\r\n        text-align: center;\r\n        background: #0066cc;\r\n        color: #fff;\r\n        border-radius: 50%;\r\n        width: 35px;\r\n        height: 35px;\r\n        font-weight: bold;\r\n        font-size: 18px;\r\n        line-height: 35px;\r\n    }\r\n\r\n    .panel p {\r\n        padding: 20px 20px 20px 60px;\r\n        border-bottom: 1px solid #ececec;\r\n        line-height: 140%;\r\n    }\r\n\r\n@media (max-width: 580px) {\r\n    .faqBox .accordion {\r\n        font-size: 15px;\r\n        padding: 15px 0 15px 40px;\r\n    }\r\n\r\n    .accordion .tit_bg {\r\n        top: 11px;\r\n        left: 6px;\r\n        width: 26px;\r\n        height: 26px;\r\n        font-size: 16px;\r\n        line-height: 26px;\r\n    }\r\n\r\n    .panel .tit_bg {\r\n        top: 11px;\r\n        left: 6px;\r\n        width: 26px;\r\n        height: 26px;\r\n        font-size: 16px;\r\n        line-height: 26px;\r\n    }\r\n\r\n    .panel p {\r\n        padding: 15px 15px 15px 40px;\r\n    }\r\n}\r\n\r\n\r\n\r\n\r\n\r\n/* 전자출결시스템 */\r\n.step_class {\r\n    display: table;\r\n    width: 100%;\r\n}\r\n\r\n    .step_class li {\r\n        display: table-cell;\r\n        width: 22%;\r\n        height: 100%;\r\n        text-align: center;\r\n        background: #016fd1;\r\n        border-radius: 10px;\r\n    }\r\n\r\n        .step_class li div {\r\n            padding: 15px 10px;\r\n            color: #fff;\r\n            height: 100%;\r\n            vertical-align: middle;\r\n        }\r\n\r\n        .step_class li.arw {\r\n            width: 4%;\r\n            height: 100%;\r\n            vertical-align: middle;\r\n            background: #fff;\r\n        }\r\n\r\n            .step_class li.arw i {\r\n                font-size: 20px;\r\n                color: #ddd;\r\n            }\r\n\r\n@media (max-width: 850px) {\r\n    .step_class li {\r\n        border-radius: 5px;\r\n    }\r\n\r\n        .step_class li div {\r\n            padding: 15px 10px;\r\n            font-size: 15px;\r\n        }\r\n\r\n        .step_class li.arw i {\r\n            font-size: 16px;\r\n        }\r\n}\r\n\r\n@media (max-width: 680px) {\r\n    .step_class li {\r\n        display: block;\r\n        width: 100%;\r\n    }\r\n\r\n        .step_class li.arw {\r\n            width: 100%;\r\n            padding: 10px 0;\r\n        }\r\n\r\n            .step_class li.arw i {\r\n                font-size: 20px;\r\n                transform: rotate(90deg);\r\n            }\r\n}\r\n\r\n\r\n\r\n\r\n\r\n/* 학생활동/지원  */\r\n.act {\r\n    display: table;\r\n    width: 100%;\r\n}\r\n\r\n    .act dt {\r\n        display: table-cell;\r\n        width: 130px;\r\n        padding: 20px 0;\r\n        background: #f4f4f4;\r\n        border-radius: 15px;\r\n        vertical-align: middle;\r\n        text-align: center;\r\n    }\r\n\r\n        .act dt img {\r\n            width: 80px;\r\n        }\r\n\r\n    .act dd {\r\n        display: table-cell;\r\n        font-size: 18px;\r\n        color: #000;\r\n        padding-left: 30px;\r\n        line-height: 130%;\r\n        text-align: left;\r\n        vertical-align: middle;\r\n    }\r\n\r\n.s_card {\r\n    display: table;\r\n    width: 100%;\r\n}\r\n\r\n    .s_card dt {\r\n        display: table-cell;\r\n        width: 150px;\r\n    }\r\n\r\n        .s_card dt img {\r\n            width: 150px;\r\n        }\r\n\r\n    .s_card dd {\r\n        display: table-cell;\r\n        padding-left: 30px;\r\n        line-height: 130%;\r\n        text-align: left;\r\n        vertical-align: middle;\r\n    }\r\n\r\nspan.bus {\r\n    display: inline-block;\r\n    width: 30px;\r\n    height: 30px;\r\n    border-radius: 50%;\r\n    background: #2868b4;\r\n}\r\n\r\n    span.bus i {\r\n        font-size: 17px;\r\n        color: #fff;\r\n        line-height: 30px;\r\n    }\r\n\r\n.busDayTable {\r\n    background: #ecf2f7;\r\n    padding: 30px;\r\n    margin: 60px 0 30px;\r\n}\r\n\r\n.bus_tt {\r\n    width: 100%;\r\n    border-collapse: separate;\r\n    border-spacing: 2px 5px;\r\n}\r\n\r\n    .bus_tt th {\r\n        width: 150px;\r\n        border-right: 2px solid #2868b4;\r\n        padding: 5px;\r\n        text-align: left;\r\n        color: #000;\r\n    }\r\n\r\n    .bus_tt td {\r\n        padding: 5px;\r\n        text-align: left;\r\n    }\r\n\r\n        .bus_tt td a {\r\n            display: inline-block;\r\n            background: #fff;\r\n            border-radius: 5px;\r\n            margin: 2px;\r\n            padding: 3px 10px;\r\n            font-size: 15px;\r\n        }\r\n\r\n            .bus_tt td a.active {\r\n                display: inline-block;\r\n                background: #2868b4;\r\n                color: #fff;\r\n            }\r\n\r\n.menuHead {\r\n    background: #5277a4 !important;\r\n    height: 50px;\r\n}\r\n\r\n    .menuHead .tit_day {\r\n        font-size: 20px;\r\n        padding: 0 20px;\r\n        color: #fff !important;\r\n    }\r\n\r\n    .menuHead a i {\r\n        color: #fff;\r\n        font-size: 20px;\r\n    }\r\n\r\n.img_cafe {\r\n    width: 100%\r\n}\r\n\r\n@media (max-width: 1240px) {\r\n    .img_cafe {\r\n        width: auto;\r\n        height: 150px;\r\n    }\r\n}\r\n\r\n@media (max-width: 850px) {\r\n    .act dt {\r\n        padding: 15px 0;\r\n        border-radius: 10px;\r\n    }\r\n\r\n        .act dt img {\r\n            width: 60px;\r\n        }\r\n\r\n    .act dd {\r\n        font-size: 17px;\r\n        padding-left: 20px;\r\n    }\r\n\r\n    span.bus {\r\n        width: 26px;\r\n        height: 26px;\r\n        margin: 0 5px;\r\n    }\r\n\r\n        span.bus i {\r\n            font-size: 16px;\r\n            line-height: 26px;\r\n        }\r\n\r\n    .busDayTable {\r\n        padding: 20px;\r\n        margin: 40px 0 10px;\r\n    }\r\n\r\n    .bus_tt th {\r\n        width: 120px;\r\n    }\r\n}\r\n\r\n@media (max-width: 680px) {\r\n    .act dt {\r\n        width: 80px;\r\n        padding: 10px 0;\r\n        border-radius: 5px;\r\n    }\r\n\r\n        .act dt img {\r\n            width: 56px;\r\n        }\r\n\r\n    .act dd {\r\n        font-size: 16px;\r\n        padding-left: 15px;\r\n    }\r\n\r\n        .act dd br {\r\n            display: none;\r\n        }\r\n\r\n    .s_card dt {\r\n        width: 120px;\r\n    }\r\n\r\n        .s_card dt img {\r\n            width: 100%;\r\n        }\r\n\r\n    .s_card dd {\r\n        padding-left: 20px;\r\n        line-height: 130%;\r\n    }\r\n\r\n    .busDayTable {\r\n        padding: 10px;\r\n        margin: 30px 0 10px;\r\n    }\r\n\r\n    .bus_tt {\r\n        border-spacing: 2px 3px;\r\n    }\r\n\r\n        .bus_tt th,\r\n        .bus_tt td {\r\n            padding: 3px 5px;\r\n        }\r\n\r\n            .bus_tt td a {\r\n                padding: 3px 8px;\r\n                font-size: 14px;\r\n            }\r\n\r\n    .menuHead {\r\n        height: 40px;\r\n    }\r\n\r\n        .menuHead .tit_day {\r\n            font-size: 17px;\r\n            padding: 0 8px;\r\n        }\r\n\r\n        .menuHead a i {\r\n            font-size: 15px;\r\n        }\r\n}\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n/* 교내/시설안내 */\r\n.siteSearch {\r\n    background: #ecf2f7;\r\n    padding: 20px 30px;\r\n    margin: 0 0 30px;\r\n}\r\n\r\n    .siteSearch dl {\r\n        display: table;\r\n        width: 100%;\r\n        padding: 15px 0;\r\n    }\r\n\r\n    .siteSearch dt {\r\n        display: table-cell;\r\n        width: 200px;\r\n        color: #000;\r\n        font-size: 16px;\r\n        vertical-align: middle;\r\n    }\r\n\r\n    .siteSearch dd {\r\n        display: table-cell;\r\n        width: calc(100% - 200px);\r\n        position: relative;\r\n    }\r\n\r\n        .siteSearch dd li a {\r\n            -webkit-transition: .2s ease-in-out;\r\n            transition: .2s ease-in-out;\r\n        }\r\n\r\n            .siteSearch dd li a:hover {\r\n                background: #2868b4;\r\n                color: #fff;\r\n            }\r\n\r\n.searchword {\r\n    width: calc(100% - 80px);\r\n    background: #fff;\r\n    height: 40px;\r\n    line-height: 40px;\r\n    border: 0;\r\n    text-indent: 10px;\r\n}\r\n\r\n.btn_website {\r\n    position: absolute;\r\n    right: 0;\r\n    top: 0;\r\n    display: inline-block;\r\n    width: 80px;\r\n    line-height: 42px;\r\n    text-align: center;\r\n    background: #2868b4;\r\n    color: #fff;\r\n    font-size: 18px;\r\n}\r\n\r\n.kor li {\r\n    float: left;\r\n}\r\n\r\n    .kor li a {\r\n        display: inline-block;\r\n        width: 30px;\r\n        height: 30px;\r\n        line-height: 30px;\r\n        border-radius: 3px;\r\n        background: #fff;\r\n        color: #333;\r\n        text-align: center;\r\n        margin-right: 3px;\r\n        margin-bottom: 3px;\r\n    }\r\n\r\n    .kor li:last-child a {\r\n        width: auto;\r\n        padding: 0 10px;\r\n    }\r\n\r\n.list_category li {\r\n    float: left;\r\n}\r\n\r\n    .list_category li a {\r\n        display: inline-block;\r\n        height: 30px;\r\n        padding: 0 15px;\r\n        line-height: 30px;\r\n        border-radius: 3px;\r\n        background: #fff;\r\n        color: #333;\r\n        margin-right: 3px;\r\n        margin-bottom: 3px;\r\n    }\r\n\r\n.btn_hompageRegi {\r\n    display: inline-block;\r\n    background: #fff;\r\n    font-size: 14px;\r\n    padding: 5px 10px;\r\n    text-align: center;\r\n    border: 1px solid #a7b6c8;\r\n}\r\n\r\n.etc_seacharea {\r\n    position: relative;\r\n    overflow: hidden;\r\n    clear: both;\r\n    width: 100%;\r\n}\r\n\r\n    .etc_seacharea .leftArea {\r\n        float: left;\r\n        overflow: hidden;\r\n        padding: 30px 0 30px 0px;\r\n        width: 49%;\r\n    }\r\n\r\n    .etc_seacharea .rightArea {\r\n        float: right;\r\n        overflow: hidden;\r\n        padding: 30px 0 30px 0px;\r\n        width: 49%;\r\n    }\r\n\r\n.sc_result_list_area {\r\n    border-top: 3px solid #231f20;\r\n}\r\n\r\n    .sc_result_list_area li {\r\n        padding: 15px 5px;\r\n        border-bottom: 1px solid #ddd;\r\n        position: relative;\r\n    }\r\n\r\n.title_sc_result_area {\r\n    width: calc(100% - 60px);\r\n}\r\n\r\n.btn_enroll {\r\n    position: absolute;\r\n    right: 10px;\r\n    top: 7px;\r\n}\r\n\r\n    .btn_enroll a {\r\n        display: inline-block;\r\n        background: #2868b4;\r\n        width: 32px;\r\n        height: 32px;\r\n        border-radius: 3px;\r\n        text-align: center;\r\n    }\r\n\r\n        .btn_enroll a i {\r\n            color: #fff;\r\n            line-height: 32px;\r\n        }\r\n\r\n.searchBox {\r\n    background: #ecf2f7;\r\n    padding: 20px;\r\n    margin: 0 0 30px;\r\n}\r\n\r\n    .searchBox dl {\r\n        display: table;\r\n        width: 100%;\r\n    }\r\n\r\n    .searchBox dt {\r\n        display: table-cell;\r\n        width: 100px;\r\n        color: #000;\r\n        font-size: 16px;\r\n        vertical-align: middle;\r\n    }\r\n\r\n        .searchBox dt label {\r\n            color: #000;\r\n            font-size: 16px;\r\n        }\r\n\r\n    .searchBox dd {\r\n        display: table-cell;\r\n        width: calc(100% - 100px);\r\n        position: relative;\r\n    }\r\n\r\n        .searchBox dd select {\r\n            height: 30px;\r\n            border: 1px solid #fff;\r\n        }\r\n\r\n            .searchBox dd select.sel_ep {\r\n                width: 100px;\r\n                margin-right: 10px;\r\n            }\r\n\r\n    .searchBox .searchword_tel {\r\n        min-width: 30%;\r\n        background: #fff;\r\n        height: 30px;\r\n        line-height: 30px;\r\n        border: 0;\r\n        text-indent: 10px;\r\n    }\r\n\r\n    .searchBox .searchword_ep {\r\n        min-width: 300px;\r\n        background: #fff;\r\n        height: 30px;\r\n        line-height: 30px;\r\n        border: 0;\r\n        text-indent: 10px;\r\n    }\r\n\r\n    .searchBox .submit {\r\n        display: inline-block;\r\n        width: 60px;\r\n        line-height: 30px;\r\n        text-align: center;\r\n        background: #2868b4;\r\n        color: #fff;\r\n        font-size: 15px;\r\n        border: none;\r\n    }\r\n\r\n.tbl_ep {\r\n    margin-bottom: 40px;\r\n    border-top: 2px solid #555;\r\n}\r\n\r\n    .tbl_ep table {\r\n        width: 100%;\r\n        border-right: 1px solid #d8d8d8;\r\n    }\r\n\r\n        .tbl_ep table tbody tr th {\r\n            vertical-align: middle;\r\n            color: #000;\r\n            background: #f2f3f6;\r\n            text-align: center;\r\n            padding: 15px;\r\n            border: 1px solid #ddd;\r\n        }\r\n\r\n        .tbl_ep table tr td.tRow {\r\n            text-align: center;\r\n            color: #000;\r\n            background: #f2f3f6;\r\n        }\r\n\r\n        .tbl_ep table tr td {\r\n            padding: 15px;\r\n            text-align: left;\r\n            vertical-align: middle;\r\n            color: #4d4d4d;\r\n            border: 1px solid #ddd\r\n        }\r\n\r\n        .tbl_ep table tr:first-child th,\r\n        .tbl_ep table tr:first-child td {\r\n            border-top: none;\r\n        }\r\n\r\n        .tbl_ep table tr.on th,\r\n        .tbl_ep table tr.on td {\r\n            background: #f2f3f6;\r\n        }\r\n\r\n    .tbl_ep + h4.dot {\r\n        margin-top: -20px;\r\n    }\r\n\r\n.liBulDash > li p.liBulDotS + .tbl_ep {\r\n    margin-top: 9px;\r\n}\r\n\r\n.tbl_ep table tr.topline {\r\n    border-top: 2px solid #555;\r\n}\r\n\r\n.aedUse {\r\n    margin-bottom: 30px;\r\n    padding-bottom: 30px;\r\n    border-bottom: 1px solid #e8e8e8;\r\n}\r\n\r\n    .aedUse:after {\r\n        content: \" \";\r\n        display: block;\r\n        clear: both;\r\n        height: 0;\r\n        visibility: hidden;\r\n    }\r\n    /* 기타 브라우져*/\r\n    .aedUse dt {\r\n        float: left;\r\n        width: 215px;\r\n    }\r\n\r\n    .aedUse dd {\r\n        float: right;\r\n        width: calc(100% - 270px);\r\n    }\r\n\r\n\r\n\r\n@media (max-width: 850px) {\r\n    .siteSearch {\r\n        padding: 15px 20px;\r\n        margin: 0 0 25px;\r\n    }\r\n\r\n        .siteSearch dt {\r\n            display: block;\r\n            width: 100%;\r\n            font-size: 15px;\r\n            margin-bottom: 8px;\r\n        }\r\n\r\n        .siteSearch dd {\r\n            display: block;\r\n            width: 100%;\r\n        }\r\n\r\n    .searchword {\r\n        width: calc(100% - 60px);\r\n        height: 35px;\r\n        line-height: 35px\r\n    }\r\n\r\n    .btn_website {\r\n        width: 60px;\r\n        line-height: 37px;\r\n        font-size: 16px;\r\n    }\r\n\r\n    .searchBox {\r\n        padding: 10px;\r\n        margin: 0 0 25px;\r\n    }\r\n\r\n        .searchBox .searchword_tel {\r\n            min-width: 45%;\r\n        }\r\n\r\n        .searchBox .searchword_ep {\r\n            min-width: 35%\r\n        }\r\n\r\n    .tbl_ep table tbody tr th {\r\n        font-size: 15px;\r\n        padding: 12px 5px;\r\n    }\r\n\r\n    .tbl_ep table tr td {\r\n        font-size: 15px;\r\n        padding: 12px 5px;\r\n    }\r\n\r\n    .aedUse dt {\r\n        width: 30%;\r\n        text-align: center;\r\n    }\r\n\r\n        .aedUse dt img {\r\n            width: 100%;\r\n            max-width: 215px;\r\n        }\r\n\r\n    .aedUse dd {\r\n        width: 65%;\r\n    }\r\n}\r\n\r\n@media (max-width: 580px) {\r\n    .etc_seacharea .leftArea {\r\n        width: 100%;\r\n        padding: 10px 0 0;\r\n    }\r\n\r\n    .etc_seacharea .rightArea {\r\n        width: 100%;\r\n        padding: 0;\r\n    }\r\n\r\n        .etc_seacharea .rightArea .sc_result_list_area {\r\n            border-top: none;\r\n        }\r\n\r\n    .searchBox dt {\r\n        display: none;\r\n    }\r\n\r\n    .searchBox dt {\r\n        width: 100%;\r\n    }\r\n\r\n    .searchBox .searchword_ep {\r\n        width: 100%;\r\n        margin: 5px 0;\r\n    }\r\n\r\n    .aedUse {\r\n        margin-bottom: 20px;\r\n        padding-bottom: 20px;\r\n    }\r\n\r\n        .aedUse dt {\r\n            width: 100%;\r\n        }\r\n\r\n        .aedUse dd {\r\n            width: 100%;\r\n            margin-top: 20px;\r\n        }\r\n}\r\n\r\n@media (max-width: 480px) {\r\n    .searchBox dd select {\r\n        height: 30px;\r\n        width: 100%;\r\n        margin-bottom: 5px;\r\n    }\r\n\r\n    .searchBox .searchword_tel {\r\n        width: 100%;\r\n        margin-bottom: 5px;\r\n    }\r\n\r\n    .searchBox .searchword_ep {\r\n        width: 100%;\r\n        margin: 0 0 5px;\r\n    }\r\n\r\n    .searchBox .submit {\r\n        width: 100%;\r\n    }\r\n}\r\n\r\n\r\n\r\n\r\n\r\n/* sitemap */\r\n.sitemapBox {\r\n    float: left;\r\n    width: 18%;\r\n    margin: 0 1% 50px;\r\n}\r\n\r\n    .sitemapBox dt {\r\n        margin-bottom: 5px;\r\n        letter-spacing: -0.05em;\r\n        padding: 11px 0 15px 18px;\r\n        font-size: 18px;\r\n        color: #37373b;\r\n        font-weight: 600;\r\n        border-bottom: 2px solid #316bc2;\r\n    }\r\n\r\n    .sitemapBox dd {\r\n        padding: 8px 0 8px 18px;\r\n        border-bottom: 1px solid #d5dde8;\r\n    }\r\n\r\n/* 장학-240213 */\r\n.gradeflex {\r\n    display: flex;\r\n}\r\n\r\n@media (max-width: 768px) {\r\n    .gradeflex {\r\n        flex-direction: column;\r\n    }\r\n}"
