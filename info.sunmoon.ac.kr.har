          "content": {
            "size": 27043,
            "mimeType": "text/css",
            "text": "@charset \"utf-8\";\r\n@import url('reset.css');\r\n@import url('contents.css');\r\n@import url('https://cdn.iconmonstr.com/1.3.0/css/iconmonstr-iconic-font.min.css');\r\n@import url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.8.2/css/all.min.css');\r\n\r\n\r\n\r\n#all_wrap {\r\n}\r\n\r\n#header {\r\n}\r\n\r\n    #header .wrap {\r\n        height: 90px;\r\n        background: #fff;\r\n    }\r\n\r\n.wrap {\r\n    position: relative;\r\n    width: 100%;\r\n    max-width: 1200px;\r\n    margin: 0 auto;\r\n}\r\n\r\n    .wrap:after {\r\n        content: \" \";\r\n        display: block;\r\n        clear: both;\r\n        height: 0;\r\n        visibility: hidden;\r\n    }\r\n/* 기타 브라우져*/\r\n\r\n#header .logo\t\t\t\t\t\t\t{position:absolute; left:0; top:29px;}\r\n#header .logo img\t\t\t\t\t\t{width:221px;}\r\n#header .head_r\t\t\t\t\t\t\t{position:absolute; right:0; top:27px;}\r\n#header .head_r\t.until\t\t\t\t\t{float:left; margin-left:15px; margin-top:6px;}\r\n#header .head_r\t.until li\t\t\t\t{float:left; font-family:\"Noto Sans KR\", Sans-serif; padding:0 10px; background:url('/images/bu_gray.gif') no-repeat 0 12px;}\r\n#header .head_r\t.until li:first-child\t{background:none;}\r\n#header .head_r\t.until li a\t\t\t\t{font-family:\"Noto Sans KR\", Sans-serif;}\r\n    #header .head_r .lang {\r\n        float: left;\r\n        margin-top: 6px;\r\n        margin-left: 10px;\r\n        overflow: hidden;\r\n        height: 30px;\r\n    }\r\n\r\n        #header .head_r .lang #google_translate_element span {\r\n            display: none;\r\n        }\r\n#header .gnbInfo\t\t\t\t\t\t{position:absolute; right:10px; bottom:8px; font-size:13px;}\r\n#header .gnbInfo i\t\t\t\t\t\t{color:#afcff6; vertical-align:middle;}\r\n.hd_search\t\t\t\t\t\t\t\t{float:left; background:#eee; border-radius:60px; width:215px; height:35px; line-height:0;}\r\n.hd_search input\t\t\t\t\t\t{border:0; background:#eee; height:32px; width:160px; margin-left:13px; margin-bottom:5px; outline:none;}\r\n.hd_search button\t\t\t\t\t\t{border:0; height:32px; background:none; vertical-align:top;}\r\n.hd_search button img\t\t\t\t\t{width:20px; margin-top:2px;}\r\n\r\n@media (max-width: 1240px) {\r\n    .wrap {\r\n        width: 96%;\r\n    }\r\n}\r\n\r\n@media (max-width: 1100px) {\r\n    #header .wrap {\r\n        height: 70px;\r\n    }\r\n\r\n    #header .logo {\r\n        position: relative;\r\n        top: 15px;\r\n        text-align: center;\r\n    }\r\n\r\n    #header .head_r {\r\n        display: none;\r\n    }\r\n}\r\n\r\n@media (max-width: 580px) {\r\n    .wrap {\r\n        width: 94%;\r\n    }\r\n\r\n    #header .wrap {\r\n        height: 60px;\r\n    }\r\n\r\n    #header .logo {\r\n        position: relative;\r\n        top: 13px;\r\n        text-align: center;\r\n    }\r\n\r\n        #header .logo img {\r\n            width: 180px;\r\n        }\r\n}\r\n\r\n\r\n\r\n\r\n/* 메인메뉴 */\r\n#gnb {\r\n    position: relative;\r\n    background: #2868b4;\r\n    z-index: 100;\r\n}\r\n\r\n    #gnb > ul {\r\n        max-width: 1200px;\r\n        margin: 0 auto;\r\n    }\r\n\r\n        #gnb > ul:after {\r\n            content: \"\";\r\n            clear: both;\r\n            display: block;\r\n            height: 0;\r\n            visibility: hidden;\r\n        }\r\n\r\n        #gnb > ul > li {\r\n            position: relative;\r\n            float: left;\r\n            padding: 0px;\r\n            text-align: left;\r\n            width: 14.2%;\r\n        }\r\n\r\n            #gnb > ul > li.current, #gnb ul > li.atv {\r\n            }\r\n\r\n                #gnb > ul > li.current > a, #gnb ul > li.atv > a {\r\n                    text-decoration: none;\r\n                    color: #5da6ff;\r\n                }\r\n\r\n            #gnb > ul > li > a:focus {\r\n                text-decoration: none;\r\n                color: #fff;\r\n            }\r\n\r\n            #gnb > ul > li > a {\r\n                display: block;\r\n                font-size: 18px;\r\n                line-height: 55px;\r\n                color: #fff;\r\n                font-family: \"Noto Sans KR\", Sans-serif;\r\n                text-align: center;\r\n            }\r\n\r\n                #gnb > ul > li > a > i {\r\n                    color: #afcff6\r\n                }\r\n\r\n    #gnb ul li .menu {\r\n        display: none;\r\n        overflow: hidden;\r\n        left: 0;\r\n        z-index: 500;\r\n        width: 100%;\r\n        padding-top: 15px;\r\n    }\r\n\r\n        #gnb ul li .menu a {\r\n            display: block;\r\n            padding: 0;\r\n        }\r\n\r\n        #gnb ul li .menu ul {\r\n            background: none; /*opacity:0.5; filter:alpha(opacity=50); -ms-filter:alpha(opacity=50);*/\r\n        }\r\n\r\n            #gnb ul li .menu ul li {\r\n                float: none;\r\n                padding: 0 8px 0 5px;\r\n                text-align: left;\r\n            }\r\n\r\n                #gnb ul li .menu ul li a {\r\n                    width: 100%;\r\n                    padding: 5px 0;\r\n                    font-size: 14px;\r\n                    line-height: 16px;\r\n                    color: #666;\r\n                    font-weight: 300;\r\n                }\r\n\r\n                    #gnb ul li .menu ul li a:hover {\r\n                        color: #2868b4;\r\n                        text-decoration: none;\r\n                        font-weight: 600;\r\n                    }\r\n\r\n    #gnb ul li.current .menu { /*background:#f5f5f5;*/\r\n    }\r\n/*#gnb ul li.current .menu ul\t\t\t{opacity:1; filter:alpha(opacity=100); -ms-filter:alpha(opacity=100);}\r\n#gnb ul li.current .menu ul li.current {background:#f1d934;}*/\r\n#gnb_background {\r\n    width: 100%;\r\n    height: 370px;\r\n    margin: auto 0;\r\n    display: none;\r\n    overflow: hidden;\r\n    left: 0;\r\n    z-index: 90;\r\n    background: rgba(243, 252, 254, 1);\r\n    border-bottom: 1px solid #ced8eb;\r\n}\r\n\r\n/* 모바일메뉴 */\r\n.mobileMenu {\r\n    position: absolute;\r\n    left: 15px;\r\n    top: 23px;\r\n    display: none;\r\n}\r\n\r\n    .mobileMenu img {\r\n        width: 25px;\r\n    }\r\n\r\n.sidenav {\r\n    height: 100%;\r\n    width: 0;\r\n    position: fixed;\r\n    z-index: 100;\r\n    top: 0;\r\n    left: 0;\r\n    background-color: #242f42;\r\n    overflow-x: hidden;\r\n    transition: 0.5s;\r\n}\r\n\r\n    .sidenav .mGnb_top {\r\n        position: relative;\r\n        background: #40567c;\r\n        width: 100%;\r\n        min-width: 320px;\r\n    }\r\n\r\n        .sidenav .mGnb_top p {\r\n            display: block;\r\n            line-height: 60px;\r\n            font-size: 14px;\r\n            color: #eee;\r\n            padding-left: 5%;\r\n        }\r\n\r\n            .sidenav .mGnb_top p i {\r\n                color: #afcff6;\r\n                vertical-align: middle;\r\n                padding-right: 5px;\r\n            }\r\n\r\n        .sidenav .mGnb_top .closebtn {\r\n            position: absolute;\r\n            top: 0px;\r\n            right: 0px;\r\n            width: 60px;\r\n            line-height: 60px;\r\n            background: #c8c8c8;\r\n            font-size: 36px;\r\n            color: #fff;\r\n            cursor: pointer;\r\n            text-align: center;\r\n        }\r\n\r\n#d-schedule {\r\n    display: block;\r\n    width: 90%;\r\n    min-width: 300px;\r\n    margin: 0 auto;\r\n}\r\n\r\n    #d-schedule > li > a {\r\n        display: block;\r\n        color: #fff;\r\n        padding: 10px 0;\r\n        font: 20px/150% 'NanumSquare';\r\n        text-align: left;\r\n        border-bottom: 1px solid #40567c\r\n    }\r\n\r\n        #d-schedule > li > a.open {\r\n            color: #6e85ae;\r\n            font-weight: 600;\r\n        }\r\n\r\n        #d-schedule > li > a i {\r\n            color: #afcff6;\r\n            padding-left: 5px;\r\n        }\r\n\r\n    #d-schedule > li > ul {\r\n        display: none;\r\n        padding: 10px 0;\r\n        border-bottom: 1px solid #40567c\r\n    }\r\n\r\n        #d-schedule > li > ul > li > a {\r\n            display: block;\r\n            color: #9ea9bb;\r\n            padding: 5px 0;\r\n            font: 18px/140% 'NanumSquare';\r\n            cursor: pointer;\r\n            padding-left: 10px;\r\n        }\r\n\r\n            #d-schedule > li > ul > li > a:hover {\r\n                color: #6e85ae;\r\n            }\r\n\r\n@media (max-width: 1100px) {\r\n    #gnb,\r\n    #header .gnbInfo {\r\n        display: none;\r\n    }\r\n\r\n    .mobileMenu {\r\n        display: block;\r\n    }\r\n}\r\n\r\n@media (max-width: 580px) {\r\n    .mobileMenu {\r\n        top: 20px;\r\n    }\r\n\r\n        .mobileMenu img {\r\n            width: 22px;\r\n        }\r\n}\r\n\r\n\r\n\r\n\r\n/* 모바일검색 */\r\n.gogglBtn {\r\n    display: none;\r\n    position: absolute;\r\n    right: 15px;\r\n    top: 23px;\r\n}\r\n\r\n    .gogglBtn .controlBtn img {\r\n        width: 25px;\r\n    }\r\n\r\n#contentsOpen {\r\n    display: none;\r\n    position: absolute;\r\n    width: 97%;\r\n    padding: 1.5%;\r\n    top: 70px;\r\n    background: #2868b4;\r\n    overflow: hidden;\r\n    z-index: 10;\r\n}\r\n\r\n    #contentsOpen .hd_search {\r\n        position: relative;\r\n        background: #eee;\r\n        border-radius: 60px;\r\n        width: 100%;\r\n        height: 35px;\r\n        line-height: 0;\r\n    }\r\n\r\n        #contentsOpen .hd_search input {\r\n            background: #eee;\r\n            height: 32px;\r\n            width: calc(100% - 55px);\r\n            margin-left: 13px;\r\n            margin-bottom: 0px;\r\n            outline: none;\r\n        }\r\n\r\n        #contentsOpen .hd_search button {\r\n            position: absolute;\r\n            right: 10px;\r\n            top: 1px;\r\n            border: 0;\r\n            height: 32px;\r\n            background: none;\r\n        }\r\n\r\n            #contentsOpen .hd_search button img {\r\n                width: 20px;\r\n                margin-top: 2px;\r\n            }\r\n\r\n@media (min-width: 1101px) {\r\n    #contentsOpen {\r\n        display: none !important;\r\n    }\r\n}\r\n\r\n@media (max-width: 1100px) {\r\n    .gogglBtn {\r\n        display: block;\r\n    }\r\n}\r\n\r\n@media (max-width: 580px) {\r\n    .gogglBtn {\r\n        top: 20px;\r\n    }\r\n\r\n        .gogglBtn .controlBtn img {\r\n            width: 22px;\r\n        }\r\n\r\n    #contentsOpen {\r\n        top: 60px\r\n    }\r\n}\r\n\r\n\r\n\r\n\r\n/* foot */\r\n#footer {\r\n    background: #242f42;\r\n    padding: 30px 0;\r\n}\r\n\r\n.footMenu li {\r\n    float: left;\r\n}\r\n\r\n    .footMenu li:before {\r\n        content: '|';\r\n        padding-right: 8px;\r\n        color: #ccc;\r\n    }\r\n\r\n    .footMenu li:first-child:before {\r\n        content: '';\r\n        padding-right: 0px;\r\n    }\r\n\r\n    .footMenu li a {\r\n        font-size: 14px;\r\n        color: #cfcfcf;\r\n        padding-right: 8px;\r\n    }\r\n\r\n.footInfo {\r\n    padding-top: 15px;\r\n}\r\n\r\n    .footInfo span {\r\n        display: inline-block;\r\n        font-size: 14px;\r\n        color: #cfcfcf;\r\n        padding-right: 12px;\r\n    }\r\n\r\n.copyright {\r\n    font-size: 14px;\r\n    color: #5f6b80;\r\n    padding-top: 5px;\r\n}\r\n\r\n@media (max-width: 1000px) {\r\n    #footer {\r\n        padding: 25px 0;\r\n        text-align: center;\r\n    }\r\n\r\n    .footMenu li {\r\n        float: none;\r\n        display: inline-block;\r\n    }\r\n}\r\n\r\n\r\n\r\n\r\n/* main */\r\n#container {\r\n    position: relative;\r\n}\r\n.main {\r\n    background: url('/imagesN/bg_main_200414.jpg') center top no-repeat;\r\n}\r\n\r\n.mSlogan {\r\n    text-align: center;\r\n    padding: 80px 0 70px\r\n}\r\n\r\n    .mSlogan p {\r\n        font-size: 26px;\r\n        color: #fff;\r\n        font-family: \"Noto Sans KR\", Sans-serif;\r\n        font-weight: 100;\r\n    }\r\n\r\n    .mSlogan h2 {\r\n        font-size: 50px;\r\n        color: #fff;\r\n        font-family: \"Noto Sans KR\", Sans-serif;\r\n        font-weight: 500;\r\n        line-height: 100%;\r\n    }\r\n\r\n        .mSlogan h2 strong {\r\n            color: #2488ff;\r\n        }\r\n\r\n@media (max-width: 1000px) {\r\n    .main {\r\n        background-size: cover;\r\n    }\r\n}\r\n\r\n@media (max-width: 850px) {\r\n    .mSlogan {\r\n        padding: 6vw 0 5vw\r\n    }\r\n\r\n        .mSlogan p {\r\n            font-size: 23px;\r\n        }\r\n\r\n        .mSlogan h2 {\r\n            font-size: 40px;\r\n        }\r\n}\r\n\r\n@media (max-width: 580px) {\r\n    .mSlogan {\r\n        padding: 40px 0 30px\r\n    }\r\n\r\n        .mSlogan p {\r\n            font-size: 18px;\r\n        }\r\n\r\n        .mSlogan h2 {\r\n            font-size: 26px;\r\n        }\r\n}\r\n\r\n\r\n\r\n\r\n\r\n#section1 {\r\n}\r\n\r\n#section2 {\r\n    padding-bottom: 135px;\r\n}\r\n\r\n.mCon {\r\n}\r\n\r\n    .mCon > div {\r\n        background: #fff;\r\n        border-radius: 20px;\r\n    }\r\n\r\n    .mCon h3 {\r\n        position: relative;\r\n        font-size: 23px;\r\n        padding-bottom: 25px;\r\n        color: #000;\r\n        font-weight: 600;\r\n    }\r\n\r\n        .mCon h3 span {\r\n            font-size: 23px;\r\n            color: #000;\r\n            font-weight: 300;\r\n        }\r\n\r\n        .mCon h3 .more {\r\n            position: absolute;\r\n            right: 0;\r\n            top: -2px;\r\n        }\r\n\r\n            .mCon h3 .more img {\r\n                width: 27px;\r\n            }\r\n\r\n.popupBox {\r\n    float: left;\r\n    width: 18.75%;\r\n    height: 240px;\r\n    padding: 2.5%;\r\n}\r\n\r\n#sliderB .popAff {\r\n    font-size: 14px;\r\n    color: #666;\r\n}\r\n\r\n#sliderB .popTit {\r\n    font-size: 18px;\r\n    color: #2868b4;\r\n    margin-top: 8px;\r\n    max-height: 42px;\r\n    overflow: hidden;\r\n    display: -webkit-box;\r\n    -webkit-line-clamp: 2;\r\n    -webkit-box-orient: vertical;\r\n    font-weight: 600;\r\n}\r\n\r\n#sliderB .popDate {\r\n    font-size: 15px;\r\n    color: #666;\r\n    margin: 15px 0;\r\n    min-height: 40px;\r\n    background: #f2f2f2;\r\n    border-radius: 10px;\r\n    padding: 15px 10px;\r\n}\r\n\r\n.slide > * {\r\n    max-width: 100%;\r\n}\r\n\r\n.slider .slide-prev, .slider .slide-next {\r\n    cursor: pointer;\r\n    height: 48px;\r\n    width: 48px;\r\n    position: absolute;\r\n    top: 50%;\r\n    margin-top: -24px;\r\n    background-color: rgba(255,255,255,0.8);\r\n    padding: 0px;\r\n    opacity: 0.8;\r\n}\r\n\r\n.slider .slide-prev {\r\n    left: 0;\r\n}\r\n\r\n.slider .slide-next {\r\n    right: 0;\r\n}\r\n\r\n    .slider .slide-prev:before, .slider .slide-next:before {\r\n        display: block;\r\n        width: 48px;\r\n        height: 48px;\r\n        font-size: 40px;\r\n        line-height: 50px;\r\n        text-align: center;\r\n        font-family: 'BenchNine', sans-serif;\r\n        position: absolute;\r\n    }\r\n\r\n.slider .slide-prev:before {\r\n    content: \"<\";\r\n}\r\n\r\n.slider .slide-next:before {\r\n    left: 3px; /* for better central alignment */\r\n    content: \">\";\r\n}\r\n\r\n.slider .slide-next:hover, .slider .slide-prev:hover {\r\n    background-color: rgba(255,255,255,0.9);\r\n}\r\n\r\n.es-caption {\r\n    position: absolute;\r\n    bottom: 0;\r\n    text-align: center;\r\n    background-color: rgba(0,0,0,0.8);\r\n    color: #fff;\r\n    font-size: 14px;\r\n    padding: 16px;\r\n    margin: 10px;\r\n    width: auto;\r\n    left: 0;\r\n    right: 0;\r\n    border-radius: 6px;\r\n}\r\n\r\nul.es-pager {\r\n    display: block;\r\n    width: 100%;\r\n    text-align: center;\r\n    margin: 7px 0;\r\n    padding: 0;\r\n    line-height: 0px;\r\n}\r\n\r\n    ul.es-pager li {\r\n        display: inline-block;\r\n        margin: 2px;\r\n        padding: 0;\r\n        height: 12px;\r\n        width: 12px;\r\n        cursor: pointer;\r\n        border-radius: 7px;\r\n        background: #ddd;\r\n    }\r\n\r\n        ul.es-pager li:hover, ul.es-pager li.act {\r\n            background-color: #2868b4;\r\n        }\r\n\r\n        ul.es-pager li.act {\r\n            cursor: default;\r\n        }\r\n\r\n@media (max-width: 1000px) {\r\n    #section2 {\r\n        padding-bottom: 90px;\r\n    }\r\n\r\n    .mCon > div {\r\n        border-radius: 15px;\r\n    }\r\n\r\n    .mCon h3 {\r\n        font-size: 20px;\r\n        padding-bottom: 20px;\r\n    }\r\n\r\n        .mCon h3 span {\r\n            font-size: 20px;\r\n        }\r\n\r\n        .mCon h3 .more img {\r\n            width: 25px;\r\n        }\r\n\r\n    .popupBox {\r\n        width: 43%;\r\n        height: 240px;\r\n        padding: 3%;\r\n    }\r\n\r\n    #sliderB .popAff {\r\n        font-size: 14px;\r\n        color: #666;\r\n    }\r\n\r\n    #sliderB .popTit {\r\n        font-size: 18px;\r\n        color: #2868b4;\r\n        margin-top: 8px;\r\n        max-height: 42px;\r\n        overflow: hidden;\r\n        display: -webkit-box;\r\n        -webkit-line-clamp: 2;\r\n        -webkit-box-orient: vertical;\r\n        font-weight: 600;\r\n    }\r\n\r\n    #sliderB .popDate {\r\n        font-size: 15px;\r\n        color: #666;\r\n        margin: 15px 0;\r\n        min-height: 40px;\r\n        background: #f2f2f2;\r\n        border-radius: 10px;\r\n        padding: 15px 10px;\r\n    }\r\n}\r\n\r\n@media (max-width: 580px) {\r\n    #section2 {\r\n        padding-bottom: 60px;\r\n    }\r\n\r\n    .mCon > div {\r\n        border-radius: 12px;\r\n    }\r\n\r\n    .mCon h3 {\r\n        font-size: 18px;\r\n        padding-bottom: 15px;\r\n    }\r\n\r\n        .mCon h3 span {\r\n            font-size: 18px;\r\n        }\r\n\r\n        .mCon h3 .more img {\r\n            width: 22px;\r\n        }\r\n\r\n    .popupBox {\r\n        width: 90%;\r\n        height: auto;\r\n        padding: 5%;\r\n    }\r\n}\r\n\r\n\r\n\r\n.scheduleBox {\r\n    float: left;\r\n    width: 18.75%;\r\n    height: 240px;\r\n    padding: 2.5%;\r\n    margin: 0 1.66%;\r\n}\r\n\r\n.schCal dl {\r\n    margin-bottom: 10px;\r\n    padding-bottom: 10px;\r\n    border-bottom: 1px solid #e6eaed;\r\n}\r\n\r\n    .schCal dl:after {\r\n        content: \"\";\r\n        clear: both;\r\n        display: block;\r\n        height: 0;\r\n        visibility: hidden;\r\n    }\r\n\r\n    .schCal dl:last-child {\r\n        border-bottom: none;\r\n        padding-bottom: 0;\r\n        margin-bottom: 0;\r\n    }\r\n\r\n    .schCal dl dt {\r\n        float: left;\r\n        width: 60px;\r\n        padding: 8px 0;\r\n        background: #2868b4;\r\n        color: #fff;\r\n        font-size: 14px;\r\n        border-radius: 5px;\r\n        text-align: center;\r\n    }\r\n\r\n    .schCal dl dd {\r\n        float: right;\r\n        width: calc(100% - 70px);\r\n    }\r\n\r\n        .schCal dl dd .schTit a {\r\n            display: block;\r\n            font-size: 14px;\r\n            color: #555;\r\n            margin: 5px 0 2px;\r\n            overflow: hidden;\r\n            white-space: nowrap;\r\n            text-overflow: ellipsis;\r\n        }\r\n\r\n        .schCal dl dd .sctDate {\r\n            font-size: 13px;\r\n            color: #888;\r\n            letter-spacing: -0.05em;\r\n        }\r\n\r\n@media (max-width: 1000px) {\r\n    .scheduleBox {\r\n        width: 43%;\r\n        height: 240px;\r\n        padding: 3%;\r\n        margin: 0 0 0 2%;\r\n    }\r\n}\r\n\r\n@media (max-width: 580px) {\r\n    .scheduleBox {\r\n        width: 90%;\r\n        height: auto;\r\n        padding: 5%;\r\n        margin: 3% 0;\r\n    }\r\n}\r\n\r\n\r\n.noticeBox {\r\n    float: left;\r\n    width: 44%;\r\n    height: 240px;\r\n    padding: 2.5%;\r\n}\r\n\r\n.latest li {\r\n    position: relative;\r\n    line-height: 38px;\r\n    color: #555;\r\n}\r\n\r\n    .latest li:after {\r\n        content: \"\";\r\n        clear: both;\r\n        display: block;\r\n        height: 0;\r\n        visibility: hidden;\r\n    }\r\n\r\n    .latest li a {\r\n        display: block;\r\n        overflow: hidden;\r\n        width: calc(100% - 120px);\r\n        text-overflow: ellipsis;\r\n        white-space: nowrap;\r\n    }\r\n\r\n    .latest li span {\r\n        position: absolute;\r\n        top: 0;\r\n        right: 0;\r\n    }\r\n\r\n@media (max-width: 1000px) {\r\n    .noticeBox {\r\n        width: 95%;\r\n        height: 240px;\r\n        padding: 2.5%;\r\n        margin-top: 2%;\r\n    }\r\n}\r\n\r\n@media (max-width: 580px) {\r\n    .noticeBox {\r\n        width: 90%;\r\n        height: auto;\r\n        padding: 5%;\r\n        margin: 0;\r\n    }\r\n\r\n    .latest li {\r\n        line-height: 32px;\r\n    }\r\n\r\n        .latest li:nth-child(4),\r\n        .latest li:nth-child(5) {\r\n            display: none;\r\n        }\r\n\r\n        .latest li a {\r\n            width: calc(100% - 90px);\r\n        }\r\n}\r\n\r\n\r\n.quickBox {\r\n    margin-top: 20px;\r\n}\r\n\r\n    .quickBox ul li {\r\n        float: left;\r\n        width: 20%;\r\n        height: 200px;\r\n        text-align: center;\r\n    }\r\n\r\n        .quickBox ul li a {\r\n            display: block;\r\n            height: 100%;\r\n            border-left: 1px solid #c6d1da;\r\n        }\r\n\r\n        .quickBox ul li:first-child a {\r\n            border-left: none;\r\n        }\r\n\r\n        .quickBox ul li:nth-child(2) a {\r\n            border-right: 1px solid #c6d1da;\r\n        }\r\n\r\n        .quickBox ul li a img {\r\n            width: 45%;\r\n            max-width: 73px;\r\n            margin-top: 47px;\r\n            -webkit-transition: .3s ease-in-out;\r\n            transition: .3s ease-in-out;\r\n        }\r\n\r\n        .quickBox ul li a div {\r\n            font-size: 20px;\r\n            margin-top: 10px;\r\n            color: #000;\r\n            font-weight: 600;\r\n        }\r\n\r\n        .quickBox ul li a span {\r\n            display: inline-block;\r\n            font-size: 14px;\r\n            width: 80px;\r\n            line-height: 28px;\r\n            background: #cacaca;\r\n            color: #fff;\r\n            border-radius: 30px;\r\n            opacity: 0;\r\n            margin-top: 15px;\r\n            -webkit-transition: .3s ease-in;\r\n            transition: .3s ease-in;\r\n        }\r\n\r\n        .quickBox ul li a:hover img {\r\n            margin-top: 30px;\r\n        }\r\n\r\n        .quickBox ul li a:hover span {\r\n            opacity: 1;\r\n            margin-top: 5px;\r\n        }\r\n\r\n        .quickBox ul li .infoVideo_main {\r\n            width: 170px;\r\n            height: 170px;\r\n            margin: 0 auto;\r\n        }\r\n\r\n.infoVideo {\r\n    position: fixed;\r\n    right: 40px;\r\n    bottom: 150px;\r\n    width: 190px;\r\n    height: 190px;\r\n    z-index: 100;\r\n}\r\n\r\n@media (max-width: 1580px) {\r\n    .infoVideo {\r\n        right: 1%;\r\n        bottom: 80px;\r\n        width: 150px;\r\n        height: 150px;\r\n    }\r\n}\r\n\r\n@media (max-width: 1000px) {\r\n    .quickBox {\r\n        margin-top: 2%;\r\n    }\r\n\r\n        .quickBox ul li {\r\n            height: 180px\r\n        }\r\n\r\n            .quickBox ul li a img {\r\n                margin-top: 35px\r\n            }\r\n\r\n            .quickBox ul li a:hover img {\r\n                margin-top: 25px;\r\n            }\r\n\r\n            .quickBox ul li .infoVideo_main {\r\n                width: auto;\r\n                height: 100%;\r\n            }\r\n\r\n    .infoVideo {\r\n        right: 19px;\r\n        bottom: 80px;\r\n        width: 140px;\r\n        height: 140px;\r\n    }\r\n}\r\n\r\n@media (max-width: 750px) {\r\n    .quickBox {\r\n        margin-top: 2%;\r\n    }\r\n\r\n        .quickBox ul li {\r\n            height: 150px\r\n        }\r\n\r\n            .quickBox ul li a img {\r\n                margin-top: 30px\r\n            }\r\n\r\n            .quickBox ul li a:hover img {\r\n                margin-top: 20px;\r\n            }\r\n\r\n            .quickBox ul li a div {\r\n                font-size: 18px;\r\n                margin-top: 8px;\r\n            }\r\n\r\n            .quickBox ul li a span {\r\n                font-size: 13px;\r\n                width: 70px;\r\n                line-height: 25px;\r\n                margin-top: 12px;\r\n            }\r\n\r\n    .infoVideo {\r\n        right: 12px;\r\n        width: 120px;\r\n        height: 120px;\r\n    }\r\n}\r\n\r\n@media (max-width: 580px) {\r\n    .quickBox {\r\n        margin-top: 3%;\r\n    }\r\n\r\n        .quickBox ul li {\r\n            height: 100px\r\n        }\r\n\r\n            .quickBox ul li a img {\r\n                margin-top: 20px\r\n            }\r\n\r\n            .quickBox ul li a div {\r\n                font-size: 14px;\r\n                margin-top: 6px;\r\n            }\r\n\r\n            .quickBox ul li a span {\r\n                display: none;\r\n            }\r\n\r\n    .infoVideo {\r\n        right: 15px;\r\n        bottom: 50px;\r\n    }\r\n}\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n/* subVisual */\r\n#sVisual {\r\n    position: relative;\r\n    height: 230px;\r\n    margin: 0;\r\n}\r\n\r\n    #sVisual .visualTit {\r\n        padding-top: 75px;\r\n        text-align: center;\r\n    }\r\n\r\n    #sVisual h2 {\r\n        font-size: 40px;\r\n        color: #fff;\r\n        text-align: center;\r\n        font-weight: 600;\r\n        letter-spacing: -0.01em;\r\n    }\r\n\r\n    #sVisual p {\r\n        font-size: 18px;\r\n        color: #fff;\r\n        text-align: center;\r\n        padding-top: 10px;\r\n        letter-spacing: 0.4em;\r\n    }\r\n\r\n.sv1 {\r\n    background: url('/imagesN/sVisual_01.jpg') no-repeat center 0;\r\n}\r\n\r\n.sv2 {\r\n    background: url('/imagesN/sVisual_02.jpg') no-repeat center 0;\r\n}\r\n\r\n.sv3 {\r\n    background: url('/imagesN/sVisual_03.jpg') no-repeat center 0;\r\n}\r\n\r\n.sv5 {\r\n    background: url('/imagesN/sVisual_05.jpg') no-repeat center 0;\r\n}\r\n\r\n.sv6 {\r\n    background: url('/imagesN/sVisual_06.jpg') no-repeat center 0;\r\n}\r\n\r\n.sv7 {\r\n    background: url('/imagesN/sVisual_07.jpg') no-repeat center 0;\r\n}\r\n\r\n.sv8 {\r\n    background: url('/imagesN/sVisual_08.jpg') no-repeat center 0;\r\n}\r\n\r\n.sv_other {\r\n    height: 50px;\r\n}\r\n\r\n.snb {\r\n    position: relative;\r\n    background: #fff;\r\n    height: 60px;\r\n    border-top: 1px solid #ddd;\r\n    border-bottom: 1px solid #ddd;\r\n}\r\n\r\n    .snb .snbBox {\r\n        width: 100%;\r\n        max-width: 1200px;\r\n        margin: 0 auto;\r\n    }\r\n\r\n    .snb .home {\r\n        float: left;\r\n        width: 60px;\r\n        height: 60px;\r\n        text-align: center;\r\n        border-right: 1px solid #ddd;\r\n        border-left: 1px solid #ddd;\r\n    }\r\n\r\n        .snb .home i {\r\n            width: 30px;\r\n            line-height: 60px;\r\n            color: #999\r\n        }\r\n\r\n.dropdown .dropbtn {\r\n    float: left;\r\n    width: 280px;\r\n    height: 60px;\r\n    background: url('/imagesN/ico_down.gif') no-repeat 255px 27px;\r\n    color: #000;\r\n    padding: 0 12px;\r\n    font-size: 18px;\r\n    border: none;\r\n    border-right: 1px solid #ddd;\r\n    cursor: pointer;\r\n    text-align: left;\r\n    letter-spacing: -0.07em;\r\n    outline: none;\r\n}\r\n/*.dropdown .dropbtn:hover, .dropdown .dropbtn:focus{background:url('/imagesN/ico_dwon.gif') no-repeat 220px 25px;}*/\r\n.dropdown2 .dropbtn {\r\n    float: left;\r\n    width: 280px;\r\n    height: 60px;\r\n    background: url('/imagesN/ico_down.gif') no-repeat 255px 27px;\r\n    color: #000;\r\n    padding: 0 12px;\r\n    font-size: 18px;\r\n    border: none;\r\n    border-right: 1px solid #ddd;\r\n    cursor: pointer;\r\n    text-align: left;\r\n    letter-spacing: -0.07em;\r\n    outline: none;\r\n}\r\n/*.dropdown2 .dropbtn:hover, .dropdown2 .dropbtn:focus{background:url('/imagesN/ico_dwon.gif') no-repeat 220px 25px;}*/\r\n.dropdown, .dropdown2 {\r\n    position: relative;\r\n    float: left;\r\n}\r\n\r\n.dropdown-content {\r\n    display: none;\r\n    positio